Inputs.InputBegan:Connect(function(input, gpe) --Looking if the player gives any type of input
	if gpe then return end --If the player interacts with gui --> return end
	if input.KeyCode == Enum.KeyCode.E then  
		ThrottelUp = true --If he presses E throttle up
	end
	
	if input.KeyCode == Enum.KeyCode.Q then
		ThrottleDown = true --If he presses Q throttle down usw. The values are not localed in this function in order to be used later on.
	end
	
	if input.KeyCode == Enum.KeyCode.S then
		pitch = -1 
	end
	
	if input.KeyCode == Enum.KeyCode.W then
		pitch = 1 
	end
	
	if input.KeyCode == Enum.KeyCode.D then
		roll = 1 
	end
	
	if input.KeyCode == Enum.KeyCode.A then
		roll = -1 
	end
	
	if input.KeyCode == Enum.KeyCode.C then
		if not fpLock then
			workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
			player.CameraMode = Enum.CameraMode.LockFirstPerson
			fpLock = true
			Modified = true
		else
			workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
			player.CameraMode = Enum.CameraMode.Classic
			fpLock = false
			Modified = false
		end
	end
	
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		shoting = true --If the mouse gets pressed, the plane shoots
	end
end)

Inputs.InputEnded:Connect(function(input) --Same as the function before, but it detects if input ends to neutralize the values  
	if input.KeyCode == Enum.KeyCode.E then  
		ThrottelUp = false 
	end
	if input.KeyCode == Enum.KeyCode.Q then 
		ThrottleDown = false 
	end
	
	if input.KeyCode == Enum.KeyCode.W then
		pitch =  0
	end

	if input.KeyCode == Enum.KeyCode.S then
		pitch = 0 
	end

	if input.KeyCode == Enum.KeyCode.D then
		roll = 0
	end

	if input.KeyCode == Enum.KeyCode.A then
		roll = 0 
	end
	
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		shoting = false --Stops shooting
	end
end)

Runservice.Heartbeat:Connect(function(dt) --EveryFrame this function checks if the player is in a plane and if he uses the controls.
	if seat then	
		local hum = char:FindFirstChild("Humanoid")
		local cam = workspace.CurrentCamera
		if not Modified then  --Makes the curser invisible and locks the cam to the cam part
			Inputs.MouseIconEnabled = false
			cam.CameraType = Enum.CameraType.Scriptable
			Modified = true
		end
		cam.CFrame = F16:FindFirstChild("Cam").CFrame
		Inputs.MouseBehavior = Enum.MouseBehavior.LockCenter  --Locks the mouse in center
		
		if not hum.SeatPart then
			Inputs.MouseBehavior = Enum.MouseBehavior.Default 
			seat = nil
			F16 = nil
			base = nil
			return
		end
		
		local Range = Config.GunRange --Importing all flight settings from the module
		local PitchSpeed = Config.PitchSpeed
		local rollSpeed = Config.rollSpeed
		local MaxSpeed = Config.MaxSpeed
		local liftForce= Config.liftForce
		local enginePower = Config.enginePower
		local dragCoeff = Config.dragCoeff
		local gravityCoeff = Config.gravityCoeff
		local takeoffSpeed = Config.TakeoffSpeed
		local throttleStep = Config.ThrottelStep
		
		local lastPitchDirec = 0
		local lastRollDirec = 0
		
		local rayParams = RaycastParams.new() --Casts a Ray to the ground to check if the plane is in the air
		rayParams.FilterDescendantsInstances = {}
		rayParams.FilterType = Enum.RaycastFilterType.Exclude
		
		local ray = workspace:Raycast(
			F16.GroundCheck.Position,
			F16.GroundCheck.CFrame.LookVector * 5e5,
			rayParams
		)
		if ray and ray.Distance >= 10 then
			airborn = true
		elseif ray and ray.Distance <= 10 then
			airborn = false
		else
			airborn = true
		end

		if ThrottleDown then 
			throttle = math.clamp(throttle - throttleStep * dt, 0, MaxSpeed)
		end 

		if ThrottelUp then 
			throttle = math.clamp(throttle + throttleStep * dt, 0, MaxSpeed) 
		end 

		local forward = base.CFrame.ZVector	
		local pitchangle = math.asin(forward.Y) 
		local accelBase = (throttle * enginePower) / 100
		local accel = accelBase * math.max(0, math.cos(pitchangle)) 
		local baseDrag = dragCoeff * currentSpeed 
		local slopeaccel = -pitchangle * gravityCoeff * currentSpeed

		currentSpeed = math.clamp(currentSpeed + (accel - baseDrag+ slopeaccel) * dt, 0, MaxSpeed) 
		bodyVelocity.Velocity = forward * currentSpeed

		local forwardSpeed = math.clamp(base.Velocity.Magnitude, 0, MaxSpeed) --Gets the forward speed
		local liftForce = forwardSpeed * liftForce                            --Calculates the lift force, so that the faster the plane goes, the further it gets pulled up.

		if currentSpeed > takeoffSpeed then 
			bodyVelocity.MaxForce = Vector3.new(1e10, liftForce, 1e10)
		else
			bodyVelocity.MaxForce = Vector3.new(1e10, 0, 1e10)
		end
		
		if pitch ~= 0 then --Checks if the pitch value changed
			lastPitchDirec = pitch
			PitchRate = math.clamp(PitchRate + pirchDecay * dt, 0, MaxPitchRate)
		else
			PitchRate = math.clamp(PitchRate - pirchDecay * dt, 0, MaxPitchRate)
		end
		
		local applyedPitch = lastPitchDirec * PitchSpeed * dt * PitchRate --Calculates the pitch that is applied on the plane
		
		if roll ~= 0 then --Checks if the roll value changed
			lastRollDirec = roll
			rollRate = math.clamp(rollRate + rollDecay * dt, 0, MaxrollRate)
		else
			rollRate = math.clamp(rollRate - rollDecay * dt, 0, MaxrollRate)
		end

		local applyedRoll = lastRollDirec * PitchSpeed * dt * rollRate --Calculates the roll that is applied on the plane
		
		local rightVector = base.CFrame.RightVector
		local upVector = base.CFrame.UpVector
		local rollAngel = math.atan2(rightVector.Y, upVector.Y)
		
		local autoYawMod = rollAngel * autoYaw
		local finalRoll = applyedRoll
		if roll == 0 and math.abs(rollAngel) > math.rad(1) then
			finalRoll = -rollAngel * autoRollStrenght
		end
		
		if not airborn then
			-- Prevent pitching nose downward on runway
			if applyedPitch > 0 then
				applyedPitch = 0
			end
		end

		local target = base.CFrame * CFrame.Angles(applyedPitch, autoYawMod * dt, finalRoll)
		
		local pitchAngle = math.deg(math.asin(target.LookVector.Y))

		local rightVector = target.RightVector
		local upVector = target.UpVector

		local rollAngle = math.deg(math.atan2(rightVector.Y, upVector.Y))
		
		if not airborn then 
			local canPitch = applyedPitch < 0 --Limits the max angels on the ground
			
			if canPitch and currentSpeed > 5 then
				alingOrientation.CFrame = target.Rotation
			end
		else
			alingOrientation.CFrame = target.Rotation
		end
		
		local verticalSpeed = base.AssemblyLinearVelocity.Y
		
		local points = {
			F16.CrashCheck1;
			F16.CrashCheck2;
			F16.CrashCheck3;
		}
		local lowestDistance = math.huge

		for _, pos in ipairs(points) do
			local ray = workspace:Raycast(
				pos.Position,
				pos.CFrame.LookVector * 5,
				rayParams
			)

			if ray then
				if currentSpeed > Config.CrashSpeed or math.abs(verticalSpeed) > Config.VerticalCrashSpeed then
					local Explosion = require(game:GetService("ReplicatedStorage").Planes:FindFirstChild("CustomExplosion"))
					local NewExplosion = Explosion.new("JetExplosion")
					NewExplosion.Lifetime = 4
					NewExplosion:SetPosition(F16.Main.Position)
					NewExplosion:SetParent(workspace)
					hum.Health = 0
					print("Crashed")
				end
			end
		end
		
		if shoting and not cooldown then
			cooldown = true
			local sound = Config.sound:Clone()
			sound.Parent = seat
			sound:Play()
			local rParams = RaycastParams.new()
			rParams.FilterDescendantsInstances = {
				player.Character,
				muzzle,
			}
			rParams.FilterType = Enum.RaycastFilterType.Exclude -- Shots a ray as bullet
			
			local RayStart = muzzle.Position
			local RayDirection = muzzle.CFrame.LookVector * Range
			local ray = workspace:Raycast(RayStart, RayDirection, rParams)
			
			if ray then
				if ray.Instance:FindFirstAncestorWhichIsA("Model") then
					local character = ray.Instance:FindFirstAncestorWhichIsA("Model")
					local humanoid = character and character:FindFirstChild("Humanoid")
					if humanoid and not cooldown then
						cooldown = true
						ray.Instance:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Humanoid"):TakeDamage(20) --I know that it needs that damage needs to be dealt
																												  --by the server but as I am not allowed to submit so many scripts, I do it here just for demonstration
					elseif ray.Instance:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("VehicleSeat") then
						local hitVehicleSeat = ray.Instance:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("VehicleSeat")
						local Hitchar = hitVehicleSeat.Occupant.Parent
						if Hitchar == char then
							return
						end
						local HitcharHum = hitVehicleSeat.Occupant
						local explosion = Instance.new("Explosion")
						explosion.Position = hitVehicleSeat.Parent.Main
						explosion.ExplosionType = Enum.ExplosionType.NoCraters
						explosion.DestroyJointRadiusPercent = 0.3
						HitcharHum.Health = 0
					end		
				end	
			end
			
			--Basic Visual tracer effect
			local targetPos = ray and ray.Position or (RayStart + RayDirection)
			local hitPart = ray and ray.Instance
			local tracer = Instance.new("Part")
			tracer.Size = Vector3.new(0.2, 0.2, 3)
			tracer.Material = Enum.Material.Neon
			tracer.Color = Color3.new(1, 0.627451, 0.101961)
			tracer.Anchored = true
			tracer.CanCollide = false
			tracer.CFrame = muzzle.CFrame
			tracer.Parent = workspace

			local distance = (targetPos - RayStart).Magnitude
			local speed = 200
			local duration = distance / speed

			local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear) --Tweens the tracer along the ray
			local tween = TweenService:Create(tracer, tweenInfo, {Position = targetPos})
			tween:Play()
			
			task.delay(Config.GunCooldown, function()
				cooldown = false
			end)
			tween.Completed:Connect(function()
				tracer:Destroy()
			end)
		end
	else	
		local char = game.Players.LocalPlayer.Character
		local hum = char:FindFirstChild("Humanoid")
		
		if Modified then --Resets all custom settings to make this script work for more than one plane
			local cam = workspace.CurrentCamera
			cam.CameraType = Enum.CameraType.Custom
			Inputs.MouseIconEnabled = true
			Inputs.MouseBehavior = Enum.MouseBehavior.Default 

			seat = nil
			F16 = nil
			base = nil
			Ammo = nil
			Modified = false
		end
		
		if hum.SeatPart then
			if hum.SeatPart:FindFirstChild("Plane") then
				if hum.SeatPart:FindFirstChild("Plane").Value == true then
					seat = hum.SeatPart -- loads all plane specific settings
					F16 = seat.Parent
					base = F16.PrimaryPart
					Ammo = seat:FindFirstChild("Ammo")
					muzzle = F16:WaitForChild("GunMuzzle")
					
					Config = require(game:GetService("ReplicatedStorage"):FindFirstChild("Planes"):FindFirstChild("Config"):FindFirstChild(seat.Name.."Config"))
					spawnedPos = base.Position

					OrientAttachment = Instance.new("Attachment", base)

					alingOrientation = Instance.new("AlignOrientation", base)
					alingOrientation.Name = "AlignOrientation"
					alingOrientation.Mode = Enum.OrientationAlignmentMode.OneAttachment
					alingOrientation.RigidityEnabled = false
					alingOrientation.MaxTorque = 1e10
					alingOrientation.CFrame = base.CFrame
					alingOrientation.Attachment0 = OrientAttachment

					bodyVelocity = Instance.new("BodyVelocity", base) --Creates the body velocity to steer the plane
					bodyVelocity.Name = "BodyVelocity"
					bodyVelocity.MaxForce = Vector3.new(1e15, 0, 1e15)
					bodyVelocity.Velocity = Vector3.zero
					
					autoYaw = Config.autoYaw
					autoRollStrenght = Config.autoRollStrenght
				end
			end
		end
	end
end)
